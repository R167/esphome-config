# Multi-stage Dockerfile for HTTP service discovery server
FROM golang:1.25-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o prometheus-mdns-http-sd ./cmd/http-sd

FROM alpine:latest
RUN apk --no-cache add ca-certificates avahi-tools
WORKDIR /root/

COPY --from=builder /app/prometheus-mdns-http-sd .

EXPOSE 8080

ENTRYPOINT ["./prometheus-mdns-http-sd"]